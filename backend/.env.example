# ─────────────────────────────────────────
# TrackMind Backend — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# ── LLM ──────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Database ─────────────────────────────
MONGODB_URI=mongodb://localhost:27017/trackmind
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/trackmind

# ── Auth ─────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=7

# ── Cognee ───────────────────────────────
# Leave empty to use local Cognee (default for hackathon)
COGNEE_API_KEY=

# Cognee local storage path (optional, defaults to ~/.cognee)
# COGNEE_DATA_PATH=./cognee_data
